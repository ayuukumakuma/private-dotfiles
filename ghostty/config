font-family = "HackGen Console NF"
font-size = 12
font-thicken = true
theme = "Catppuccin Latte"
background-opacity = 0.8
mouse-hide-while-typing = true
maximize = true
keybind = global:cmd+shift+backquote=toggle_quick_terminal
keybind = ctrl+cmd+h=goto_split:left
keybind = ctrl+cmd+j=goto_split:down
keybind = ctrl+cmd+k=goto_split:up
keybind = ctrl+cmd+l=goto_split:right
quick-terminal-position = "top"
quick-terminal-size = "35%"
quick-terminal-screen = "mouse"
quick-terminal-animation-duration = 0.12
quick-terminal-autohide = true
shell-integration = "fish"
shell-integration-features = true
macos-window-buttons = "hidden"
macos-icon = "xray"
desktop-notifications = true
