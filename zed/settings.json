{
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "git-firefly": true,
    "html": true,
    "kconfig": true,
    "nix": true,
    "tombi": true,
    "toml": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "buffer_font_family": "HackGen Console NF",
  "buffer_font_size": 13,
  "icon_theme": "Catppuccin Frappé",
  "session": {
    "trust_all_worktrees": true
  },
  "tab_size": 2,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "theme": "Catppuccin Frappé",
  "ui_font_size": 16,
  "vim_mode": true
}
