#!/usr/bin/env bash

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"
ICON_RIFT=""
ICON_FRONT_APP=""
ICON_SPOTIFY=""
ICON_CLOCK=""
ICON_BATTERY=""
ICON_INPUT_SOURCE=""

COLOR_PEACH="0xfffe640b"
COLOR_YELLOW="0xffdf8e1d"
COLOR_GREEN="0xff40a02b"
COLOR_SKY="0xff04a5e5"
COLOR_BLUE="0xff1e66f5"
COLOR_LAVENDER="0xff7287fd"
COLOR_TEXT="0xff4c4f69"
COLOR_SUBTEXT1="0xff5c5f77"
COLOR_SURFACE1="0xffbcc0cc"
COLOR_BASE="0xffeff1f5"

COLOR_ITEM_BG="0x66ccd0da"
COLOR_INPUT_SOURCE_BG="0x66bcc0cc"
COLOR_SPOTIFY_BG="0x6640a02b"
COLOR_POPUP_BG="0xf0e6e9ef"

bar=(
  height=32
  position=top
  sticky=on
  topmost=window
  padding_left=10
  padding_right=10
  color="$COLOR_BASE"
)

defaults=(
  icon.font="HackGen35 Console NF:Bold:14.0"
  icon.color="$COLOR_TEXT"
  icon.padding_left=8
  icon.padding_right=6
  label.font="HackGen35 Console NF:Regular:12.0"
  label.color="$COLOR_SUBTEXT1"
  label.padding_left=0
  label.padding_right=10
  background.height=24
  background.corner_radius=6
  updates=when_shown
)

sketchybar --bar "${bar[@]}" \
  --default "${defaults[@]}"

sketchybar --add event spotify_change com.spotify.client.PlaybackStateChanged
sketchybar --add event input_source_change AppleSelectedInputSourcesChangedNotification

sketchybar --add item rift left \
  --set rift \
    icon="$ICON_RIFT" \
    icon.color="$COLOR_BLUE" \
    icon.padding_left=10 \
    icon.padding_right=8 \
    label.padding_left=4 \
    label.padding_right=12 \
    script="$PLUGIN_DIR/rift.sh" \
    update_freq=5 \
    drawing=off \
    background.drawing=on \
    background.color="$COLOR_ITEM_BG" \
    background.padding_left=4 \
    background.padding_right=4 \
  --subscribe rift system_woke

sketchybar --add item front_app left \
  --set front_app \
    icon="$ICON_FRONT_APP" \
    icon.color="$COLOR_LAVENDER" \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched system_woke

# Right items are rendered from edge inward, so add clock first to keep it at the far right.
sketchybar --add item clock right \
  --set clock \
    icon="$ICON_CLOCK" \
    icon.color="$COLOR_YELLOW" \
    script="$PLUGIN_DIR/clock.sh" \
    update_freq=10 \
    popup.align=right \
    popup.y_offset=6 \
    popup.blur_radius=20 \
    popup.height=24 \
    popup.background.color="$COLOR_POPUP_BG" \
    popup.background.corner_radius=8 \
    popup.background.border_width=1 \
    popup.background.border_color="$COLOR_SURFACE1" \
  --subscribe clock mouse.clicked mouse.exited.global system_woke

sketchybar --add item clock_calendar_title popup.clock \
  --set clock_calendar_title \
    icon.drawing=off \
    label="March 2026" \
    label.font="HackGen35 Console NF:Bold:11.0" \
    label.color="$COLOR_YELLOW" \
    label.align=center \
    label.padding_left=10 \
    label.padding_right=10

sketchybar --add item clock_calendar_days popup.clock \
  --set clock_calendar_days \
    icon.drawing=off \
    label=" Su  Mo  Tu  We  Th  Fr  Sa " \
    label.font="HackGen35 Console NF:Regular:10.0" \
    label.color="$COLOR_BLUE" \
    label.align=center \
    label.padding_left=10 \
    label.padding_right=10

for week in 1 2 3 4 5 6; do
  sketchybar --add item "clock_calendar_week${week}" popup.clock \
    --set "clock_calendar_week${week}" \
      icon.drawing=off \
      label="                            " \
      label.font="HackGen35 Console NF:Regular:10.0" \
      label.align=center \
      label.padding_left=10 \
      label.padding_right=10 \
      background.height=18 \
      background.corner_radius=4
done

sketchybar --add item battery right \
  --set battery \
    icon="$ICON_BATTERY" \
    icon.color="$COLOR_PEACH" \
    script="$PLUGIN_DIR/battery.sh" \
    update_freq=30 \
    background.drawing=on \
    background.color="$COLOR_ITEM_BG" \
  --subscribe battery power_source_change system_woke

sketchybar --add item input_source right \
  --set input_source \
    icon="$ICON_INPUT_SOURCE" \
    icon.font="HackGen35 Console NF:Bold:14.0" \
    icon.color="$COLOR_SKY" \
    label="A" \
    script="$PLUGIN_DIR/input_source.sh" \
    label.padding_left=2 \
    label.padding_right=8 \
    background.drawing=on \
    background.color="$COLOR_INPUT_SOURCE_BG" \
  --subscribe input_source input_source_change system_woke

sketchybar --add item codex_usage right \
  --set codex_usage \
    width=dynamic \
    drawing=on \
    icon=":openai:" \
    icon.drawing=on \
    icon.font="sketchybar-app-font:Regular:15.0" \
    icon.padding_left=8 \
    icon.padding_right=8 \
    label="" \
    label.drawing=off \
    script="$PLUGIN_DIR/codex_usage.sh" \
    click_script="" \
    update_freq=300 \
    updates=on \
    background.drawing=on \
    background.color=0x01000000 \
    background.height=22 \
    background.image="" \
    background.image.drawing=off \
    background.padding_left=2 \
    background.padding_right=2 \
    popup.align=right \
    popup.y_offset=6 \
    popup.blur_radius=20 \
    popup.height=28 \
    popup.background.color="$COLOR_POPUP_BG" \
    popup.background.corner_radius=8 \
    popup.background.border_width=1 \
    popup.background.border_color="$COLOR_SURFACE1" \
  --subscribe codex_usage mouse.clicked mouse.exited.global system_woke

sketchybar --add item codex_usage_5h popup.codex_usage \
  --set codex_usage_5h \
    icon.drawing=off \
    label="5時間枠: 残り--  --:--にリセット" \
    label.padding_left=12 \
    label.padding_right=12

sketchybar --add item codex_usage_weekly popup.codex_usage \
  --set codex_usage_weekly \
    icon.drawing=off \
    label="週次枠: 残り--  --/-- --:--にリセット" \
    label.padding_left=12 \
    label.padding_right=12

sketchybar --add item codex_usage_updated popup.codex_usage \
  --set codex_usage_updated \
    icon.drawing=off \
    label="更新: --:--" \
    label.padding_left=12 \
    label.padding_right=12

sketchybar --add item spotify right \
  --set spotify \
    icon="$ICON_SPOTIFY" \
    icon.color="$COLOR_GREEN" \
    script="$PLUGIN_DIR/spotify.sh" \
    click_script="$PLUGIN_DIR/spotify.sh --toggle" \
    update_freq=15 \
    updates=on \
    drawing=off \
    scroll_texts=off \
    label.scroll_duration=600 \
    label.max_chars=34 \
    background.drawing=on \
    background.color="$COLOR_SPOTIFY_BG" \
  --subscribe spotify spotify_change media_change system_woke

sketchybar --update
